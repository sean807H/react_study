# Node modules 폴더 (의존성 라이브러리)
node_modules/

# 환경설정 파일 (환경에 따라 다를 수 있음)
.env
.env.local
.env.development
.env.test
.env.production

# 빌드된 파일 및 폴더
build/
dist/

# 로그 파일
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# 패키지 락 파일 (일반적으로 올리지 않지만 상황에 따라 포함할 수도 있음)
package-lock.json
yarn.lock

# MacOS에서 생성되는 임시 파일들
.DS_Store

# VSCode 설정 파일
.vscode/

# 다른 IDE/편집기 설정 파일
.idea/

# 기타 시스템 파일
Thumbs.db
